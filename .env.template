# QUORUM_MODE controls which embedding/adjudication backend is used.
#   sim     - deterministic, offline, zero-cost mock backend (default; no keys needed)
#   openai  - real OpenAI embeddings + chat completion for adjudication
#   bedrock - real AWS Bedrock (Titan embeddings + Claude adjudication)
QUORUM_MODE=sim

DATABASE_URL=postgresql://root@localhost:26257/quorum?sslmode=disable
EMBEDDING_DIM=128

# Required when QUORUM_MODE=openai
OPENAI_API_KEY=

# Required when QUORUM_MODE=bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Bedrock Mantle endpoint API key (Bedrock console -> API keys -> Create key).
# This is what adjudicate.py's bedrock branch actually authenticates with;
# AWS_ACCESS_KEY_ID/SECRET above are not used by the current mantle-endpoint
# integration but are left in case a future embeddings path needs classic IAM.
BEDROCK_API_KEY=

# S3 bucket for audit export (POST /events/audit-export). Optional -- if
# unset, that endpoint returns 501 rather than failing sim/openai mode.
AUDIT_S3_BUCKET=

# --- docker-compose deploy vars (used by docker-compose.yml's variable
# interpolation, so this file also needs to be copied to the repo root as
# `.env`, not just to backend/.env -- see README setup instructions) ---

# Public hostnames for the Caddy reverse proxy (prod profile only; local
# `docker compose up` hits frontend/backend directly on :3000/:8000 and
# ignores these). Caddy auto-issues Let's Encrypt certs for these, so they
# must be real, publicly resolvable hostnames, not "localhost".
DOMAIN=
API_DOMAIN=
# Baked into the frontend's client bundle at build time -- must match
# API_DOMAIN above (with scheme) for the prod build.
NEXT_PUBLIC_API_URL=
